<Application x:Class="Verkehrs_Informationen.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Verkehrs_Informationen"
             xmlns:vm="clr-namespace:Verkehrs_Informationen.Models.ViewModels"
             xmlns:views="clr-namespace:Verkehrs_Informationen.Views"
             >
    <Application.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <DataTemplate DataType="{x:Type vm:MainViewModel}">
            <views:MainWindow/>
        </DataTemplate>
    </Application.Resources>
</Application>
