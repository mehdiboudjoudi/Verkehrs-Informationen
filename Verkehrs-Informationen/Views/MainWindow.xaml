<Window x:Class="Verkehrs_Informationen.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Verkehrs_Informationen"
        xmlns:viewmodels="clr-namespace:Verkehrs_Informationen.Models.ViewModels"
        xmlns:models="clr-namespace:Verkehrs_Informationen.Models"
        mc:Ignorable="d" Height="500" Width="850">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <DropShadowEffect x:Key="DropShadow" ShadowDepth="5" BlurRadius="10" Opacity="0.3"/>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ComboBox für Straßenauswahl -->
        <StackPanel Grid.Row="0" Margin="10,10,10,5">
            <TextBlock Text="Autobahn auswählen:" FontWeight="Bold" Margin="0,0,0,5"/>
            <ComboBox x:Name="RoadList" 
                      ItemsSource="{Binding Roads.Roads}" 
                      SelectedItem="{Binding SelectedRoad}"
                      Height="30"/>
        </StackPanel>

        <!-- TabControl für Warnungen, Gesperrte Straßen, Baustellen -->
        <TabControl Grid.Row="1" Margin="10,5,10,10">
            <TabItem Header="Warnungen">
                <ListBox x:Name="WarningList" 
                         ItemsSource="{Binding Warnings}"
                         DisplayMemberPath="Title" 
                         MouseDoubleClick="WarningList_MouseDoubleClick"/>
            </TabItem>
            <TabItem Header="Gesperrte Straßen">
                <DataGrid ItemsSource="{Binding ClosedRoads}" 
                          AutoGenerateColumns="False" 
                          IsReadOnly="True" 
                          SelectionMode="Single"
                          MouseDoubleClick="ClosedRoads_MouseDoubleClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Titel" Binding="{Binding Title}" Width="2*" />
                        <DataGridTextColumn Header="Richtung" Binding="{Binding Subtitle}" Width="*" />
                        <DataGridTextColumn Header="Status" Binding="{Binding BlockedStatus}" Width="100" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="Baustellen">
                <DataGrid ItemsSource="{Binding RoadWorks}" 
                          AutoGenerateColumns="False" 
                          IsReadOnly="True" 
                          SelectionMode="Single"
                          MouseDoubleClick="RoadWorks_MouseDoubleClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Titel" Binding="{Binding Title}" Width="2*" />
                        <DataGridTextColumn Header="Richtung" Binding="{Binding Subtitle}" Width="*" />
                        <DataGridTextColumn Header="Status" Binding="{Binding BlockedStatus}" Width="100" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>

        <!-- Loading Indicator -->
        <Border x:Name="LoadingIndicator" 
                Visibility="Collapsed" 
                Background="#55FFFFFF" 
                Panel.ZIndex="10"
                Grid.Row="0"
                Grid.RowSpan="2">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="15"/>
                <TextBlock Text="Lade Verkehrsdaten..." 
                           HorizontalAlignment="Center" 
                           Margin="0,10,0,0" 
                           FontWeight="SemiBold"/>
            </StackPanel>
        </Border>

        <!-- Popup Dialog Overlay -->
        <Grid Visibility="{Binding IsDialogVisible, Converter={StaticResource BooleanToVisibilityConverter}}" 
              Background="#AA000000" 
              Panel.ZIndex="20"
              Grid.Row="0"
              Grid.RowSpan="2"
              MouseLeftButtonDown="DialogOverlay_MouseLeftButtonDown">
            <Border Background="White" 
                    MaxWidth="500" 
                    VerticalAlignment="Center" 
                    HorizontalAlignment="Center"
                    Padding="20" 
                    CornerRadius="8"
                    Effect="{StaticResource DropShadow}"
                    MouseLeftButtonDown="Dialog_MouseLeftButtonDown">
                <StackPanel>
                    <TextBlock Text="{Binding DetailTitle}" 
                               FontSize="18" 
                               FontWeight="Bold" 
                               TextWrapping="Wrap"
                               Foreground="#333333"
                               Margin="0,0,0,15"/>
                    <ScrollViewer MaxHeight="300" VerticalScrollBarVisibility="Auto" Margin="0,0,0,15">
                        <TextBlock Text="{Binding DetailDescription}" 
                                   TextWrapping="Wrap" 
                                   FontSize="13"
                                   LineHeight="18"
                                   Foreground="#555555"/>
                    </ScrollViewer>
                    <Button Content="Schließen" 
                            Command="{Binding CloseDialogCommand}" 
                            HorizontalAlignment="Right" 
                            Background="#0078D4"
                            Foreground="White"
                            Padding="15,8"
                            FontSize="12"
                            Cursor="Hand"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>