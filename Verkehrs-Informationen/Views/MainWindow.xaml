<Window x:Class="Verkehrs_Informationen.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Verkehrs_Informationen"
        xmlns:viewmodels="clr-namespace:Verkehrs_Informationen.Models.ViewModels"
        xmlns:models="clr-namespace:Verkehrs_Informationen.Models"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>

        <StackPanel>
            <TextBox x:Name="RoadInput" Text="A1" Margin="10"/>
            <Button Content="Warnungen laden" Click="LoadWarnings_Click" Margin="10"/>
            <ListBox x:Name="WarningList" DisplayMemberPath="Title" Height="200" Margin="10"/>
        </StackPanel>

    </Grid>
</Window>
