<Window x:Class="Verkehrs_Informationen.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Autobahn Info" Height="500" Width="850">
    <Grid>
        <DockPanel LastChildFill="True" Margin="10">
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="Autobahn:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBox x:Name="RoadInput" Text="A1" Width="100" Padding="3"/>
                <Button Content="Daten laden" Click="LoadData_Click" Margin="10,0,0,0" Padding="10,2"/>
            </StackPanel>

            <DataGrid x:Name="MasterGrid" 
                      AutoGenerateColumns="False" 
                      IsReadOnly="True" 
                      SelectionMode="Single" 
                      MouseDoubleClick="MasterGrid_MouseDoubleClick">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Titel" Binding="{Binding Title}" Width="2*" />
                    <DataGridTextColumn Header="Richtung" Binding="{Binding Subtitle}" Width="*" />
                    <DataGridTextColumn Header="Status" Binding="{Binding BlockedStatus}" Width="100" />
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        <Border x:Name="LoadingIndicator" 
                Visibility="Collapsed" 
                Background="#55FFFFFF" 
                Panel.ZIndex="10">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="15"/>
                <TextBlock Text="Lade Verkehrsdaten..." 
                           HorizontalAlignment="Center" 
                           Margin="0,10,0,0" 
                           FontWeight="SemiBold"/>
            </StackPanel>
        </Border>

        <Grid x:Name="DetailDialog" Visibility="Collapsed" Background="#AA000000" Panel.ZIndex="20">
            <Border Background="White" MaxWidth="500" VerticalAlignment="Center" Padding="20" CornerRadius="5">
                <StackPanel>
                    <TextBlock x:Name="DetailTitle" FontSize="16" FontWeight="Bold" Margin="0,0,0,10" TextWrapping="Wrap"/>
                    <ScrollViewer MaxHeight="250" VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="DetailDesc" TextWrapping="Wrap" FontSize="13"/>
                    </ScrollViewer>
                    <Button Content="Schließen" Click="CloseDialog_Click" HorizontalAlignment="Right" Margin="0,15,0,0" Padding="15,5"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>